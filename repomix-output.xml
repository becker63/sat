import { fireEvent, render, screen, waitFor } from "@testing-library/react";
import userEvent from "@testing-library/user-event";
import { afterEach, describe, expect, it, vi } from "vitest";
import SearchBar from "@/components/SearchBar";

const movePointer = (element: HTMLElement, x: number, y: number) => {
  fireEvent.pointerMove(element, { clientX: x, clientY: y });
};

const getContainer = () =>
  screen.getByRole("textbox").closest("[data-focused]") as HTMLElement;

afterEach(() => {
  vi.restoreAllMocks();
});

describe("SearchBar (vitest)", () => {
  it("renders input and replay button", () => {
    render(<SearchBar />);

    const input = screen.getByRole("textbox");
    const button = screen.getByRole("button", { name: /replay/i });

    expect(input).toBeInTheDocument();
    expect(button).toBeInTheDocument();
    expect(input).toHaveAttribute("placeholder", "Search symbol...");
    expect(screen.getAllByRole("textbox")).toHaveLength(1);
    expect(screen.getAllByRole("button")).toHaveLength(1);
  });

  it("invokes onReplay when the replay button is clicked", async () => {
    const user = userEvent.setup();
    const onReplay = vi.fn();

    render(<SearchBar onReplay={onReplay} />);

    await user.click(screen.getByRole("button", { name: /replay/i }));

    expect(onReplay).toHaveBeenCalledTimes(1);
  });

  it("passes the query when replay is triggered", async () => {
    const user = userEvent.setup();
    const onReplay = vi.fn();

    render(<SearchBar onReplay={onReplay} />);

    const input = screen.getByRole("textbox");

    await user.type(input, "useQuery");
    await user.click(screen.getByRole("button", { name: /replay/i }));

    expect(onReplay).toHaveBeenCalledWith("useQuery");
  });

  it("triggers replay when pressing Enter", async () => {
    const user = userEvent.setup();
    const onReplay = vi.fn();

    render(<SearchBar onReplay={onReplay} />);

    const input = screen.getByRole("textbox");

    await user.type(input, "focusManager{enter}");

    expect(onReplay).toHaveBeenCalledWith("focusManager");
  });

  it("clears the input after replay", async () => {
    const user = userEvent.setup();
    const onReplay = vi.fn();

    render(<SearchBar onReplay={onReplay} />);

    const input = screen.getByRole("textbox");

    await user.type(input, "reactQuery");
    await user.keyboard("{enter}");

    await waitFor(() => {
      expect(input).toHaveValue("");
    });
    expect(onReplay).toHaveBeenCalledTimes(1);
  });

  it("shows focus highlight when input is focused", async () => {
    const user = userEvent.setup();

    render(<SearchBar />);

    const input = screen.getByRole("textbox");

    await user.click(input);

    const container = input.closest('[data-focused="true"]');

    expect(container).toBeTruthy();
  });

  it("removes highlight when input loses focus", async () => {
    const user = userEvent.setup();

    render(<SearchBar />);

    const input = screen.getByRole("textbox");

    await user.click(input);
    await user.tab();

    const container = input.closest('[data-focused="true"]');

    expect(container).toBeNull();
  });

  it("keeps the input focused after replay", async () => {
    const user = userEvent.setup();
    const onReplay = vi.fn();

    render(<SearchBar onReplay={onReplay} />);

    const input = screen.getByRole("textbox");

    await user.type(input, "query{enter}");

    await waitFor(() => {
      expect(input).toHaveFocus();
    });
  });

  it("spawns two hover lines from the pointer center", async () => {
    render(<SearchBar />);

    const container = getContainer();

    movePointer(container, 50, 20);

    const lines = await screen.findAllByTestId("searchbar-line");
    const left = lines.find(
      (line) => line.getAttribute("data-side") === "left",
    );
    const right = lines.find(
      (line) => line.getAttribute("data-side") === "right",
    );

    expect(left).toHaveAttribute("data-state", "hover");
    expect(left).toHaveAttribute("data-start-x", "50");
    expect(left).toHaveAttribute("data-end-x", "-50");
    expect(left).toHaveAttribute("data-y", "20");

    expect(right).toHaveAttribute("data-state", "hover");
    expect(right).toHaveAttribute("data-start-x", "50");
    expect(right).toHaveAttribute("data-end-x", "150");
    expect(right).toHaveAttribute("data-y", "20");
  });

  it("moves hover lines with pointer updates", async () => {
    render(<SearchBar />);

    const container = getContainer();

    movePointer(container, 30, 18);
    movePointer(container, 90, 32);

    await waitFor(() => {
      const right = container.querySelector(
        '[data-testid="searchbar-line"][data-side="right"]',
      );

      expect(right).toHaveAttribute("data-start-x", "90");
      expect(right).toHaveAttribute("data-end-x", "190");
      expect(right).toHaveAttribute("data-y", "32");
    });
  });

  it("removes hover lines when the pointer leaves", async () => {
    render(<SearchBar />);

    const container = getContainer();

    movePointer(container, 30, 18);
    fireEvent.pointerLeave(container);

    await waitFor(() => {
      expect(screen.queryAllByTestId("searchbar-line")).toHaveLength(0);
    });
  });

  it("wraps a line around the field when the input is focused", async () => {
    const user = userEvent.setup();

    render(<SearchBar />);

    const input = screen.getByRole("textbox");
    const container = getContainer();

    movePointer(container, 44, 22);
    await screen.findAllByTestId("searchbar-line");
    fireEvent.focus(input);

    const wrapLine = await screen.findByTestId("searchbar-line");

    expect(wrapLine).toHaveAttribute("data-state", "wrap");
    expect(wrapLine).toHaveAttribute("data-origin-x", "44");
    expect(wrapLine).toHaveAttribute("data-origin-y", "22");
    expect(wrapLine).toHaveStyle({
      top: "-8px",
      left: "-8px",
      right: "-8px",
      bottom: "-8px",
    });
  });
});
