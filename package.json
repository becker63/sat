{
  "name": "sat",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "panda cssgen \"./src/**/*.{ts,tsx}\" --watch & next dev -p 5000 -H 0.0.0.0",
    "build": "panda cssgen \"./src/**/*.{ts,tsx}\" && next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "eslint . --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run test:e2e",
    "playwright:install": "playwright install",
    "shot:theme": "node src/theme/capture-react-flow.mjs"
  },
  "dependencies": {
    "@ark-ui/react": "^5.34.1",
    "@use-gesture/react": "^10.3.1",
    "@xyflow/react": "^12.10.1",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "elkjs": "^0.11.1",
    "flatten-js": "^0.6.9",
    "framer-motion": "^12.35.0",
    "jotai": "^2.18.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rxjs": "^7.8.2",
    "xstate": "^5.28.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@pandacss/dev": "^1.8.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.54",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "happy-dom": "^20.8.3",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
